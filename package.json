{
  "name": "screenflow-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "player"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:player": "npm run dev --workspace=player",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:player\"",
    "build:all": "npm run build --workspaces",
    "db:push": "npm run db:push --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

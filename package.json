{
  "name": "screenflow-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "player",
    "backend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:player": "npm run dev --workspace=player",
    "dev:shell": "npm run dev:shell --workspace=player",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:shell\"",
    "build": "npm run build --workspaces",
    "start": "npm start --workspace=backend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
